# Flask
FLASK_ENV=production
FLASK_DEBUG=0
JWT_SECRET_KEY=change-this-secret-to-a-long-random-string-at-least-32-bytes
CORS_ORIGINS=http://localhost:3000

# Database (preferred)
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:PORT/DB_NAME

# Database (fallback if DATABASE_URL not set)
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gamified_learning
